digraph infographic_builder {
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    node [fontname="Helvetica" fontsize=10 style=filled]
    edge [fontname="Helvetica" fontsize=9]
    compound=true
    newrank=true

    // ── Bundle Composition ──────────────────────────────────────

    subgraph cluster_bundle {
        label="infographic-builder bundle"
        style="rounded,dashed"
        color="#666666"
        fontcolor="#666666"
        bgcolor="#fafafa"

        bundle_md [
            label="bundle.md\n(thin root)"
            shape=note
            fillcolor="#e8f4fd"
            color="#4a90d9"
        ]

        subgraph cluster_behavior {
            label="behaviors/infographic.yaml"
            style="rounded"
            color="#b0b0b0"
            bgcolor="#f5f5f5"

            tool_nano [
                label="tool: nano-banana\n(Gemini image gen)"
                shape=component
                fillcolor="#fff3cd"
                color="#d4a017"
            ]

            tool_stitch [
                label="tool: stitch_panels\n(Pillow-based assembly)"
                shape=component
                fillcolor="#fff3cd"
                color="#d4a017"
            ]

            agent_wire [
                label="agent: infographic-builder"
                shape=component
                fillcolor="#d4edda"
                color="#28a745"
            ]

            context_wire [
                label="context: infographic-awareness.md"
                shape=component
                fillcolor="#e2d9f3"
                color="#7b5ea7"
            ]
        }

        foundation [
            label="amplifier-foundation\n(inherited tools, hooks, session)"
            shape=box3d
            fillcolor="#f0f0f0"
            color="#999999"
        ]

        bundle_md -> foundation [label="includes" style=dashed color="#999999"]
        bundle_md -> tool_nano [label="includes" style=dashed color="#999999" lhead=cluster_behavior]
    }

    // ── Runtime Flow ────────────────────────────────────────────

    subgraph cluster_runtime {
        label="Runtime Flow"
        style="rounded"
        color="#333333"
        bgcolor="#ffffff"

        user [
            label="User\n\"create an infographic\nabout the water cycle\""
            shape=oval
            fillcolor="#dbeafe"
            color="#2563eb"
        ]

        root_session [
            label="Root Session\n(reads awareness context)"
            shape=box
            fillcolor="#e8f4fd"
            color="#4a90d9"
        ]

        agent [
            label="infographic-builder\nagent"
            shape=doubleoctagon
            fillcolor="#d4edda"
            color="#28a745"
        ]

        style_guide [
            label="docs/style-guide.md\n(6 aesthetics, 12 layouts,\nreview criteria)"
            shape=note
            fillcolor="#e2d9f3"
            color="#7b5ea7"
        ]

        subgraph cluster_aesthetic {
            label="Aesthetic Selection"
            style="rounded"
            color="#b0b0b0"
            bgcolor="#f9f9f9"

            aesthetic_detect [
                label="Inline style\ndetected?"
                shape=diamond
                fillcolor="#fce4ec"
                color="#c62828"
                fontsize=9
            ]

            aesthetic_prompt [
                label="Present 6 options\n+ freeform\n(halt for user)"
                shape=box
                fillcolor="#fff3cd"
                color="#d4a017"
                fontsize=9
            ]
        }

        nano_banana [
            label="nano-banana tool\n(generate + analyze)"
            shape=hexagon
            fillcolor="#fff3cd"
            color="#d4a017"
        ]

        gemini [
            label="Gemini API\n(image generation)"
            shape=cylinder
            fillcolor="#fce4ec"
            color="#c62828"
        ]

        subgraph cluster_review {
            label="Quality Review Loop"
            style="rounded,dashed"
            color="#ff6b00"
            bgcolor="#fff8f0"

            review [
                label="Analyze output\n(5 dimensions)"
                shape=box
                fillcolor="#ffe0b2"
                color="#ff6b00"
                fontsize=9
            ]

            refine_check [
                label="Issues\nfound?"
                shape=diamond
                fillcolor="#ffe0b2"
                color="#ff6b00"
                fontsize=9
            ]

            refine [
                label="Refine & regenerate\n(max 1x)"
                shape=box
                fillcolor="#ffe0b2"
                color="#ff6b00"
                fontsize=9
            ]
        }

        stitch [
            label="stitch_panels\n(vertical / horizontal)"
            shape=hexagon
            fillcolor="#fff3cd"
            color="#d4a017"
        ]

        image [
            label="./infographic.png\n(+ individual panels)"
            shape=folder
            fillcolor="#e8f5e9"
            color="#2e7d32"
        ]
    }

    // ── Main Flow Edges ─────────────────────────────────────────

    user -> root_session [label="1. request" color="#2563eb" penwidth=1.5]
    root_session -> agent [label="2. delegate()" color="#28a745" penwidth=1.5]
    agent -> style_guide [label="3. load style guide" style=dashed color="#7b5ea7"]
    agent -> aesthetic_detect [label="4. aesthetic\n    selection" color="#c62828"]
    aesthetic_detect -> aesthetic_prompt [label="no" color="#c62828"]
    aesthetic_detect -> nano_banana [label="yes\n(shortcut)" color="#28a745"]
    aesthetic_prompt -> nano_banana [label="user picks" color="#d4a017"]
    nano_banana -> gemini [label="API call" color="#c62828"]
    gemini -> nano_banana [label="image data" color="#c62828" style=dashed]

    // Quality review loop
    nano_banana -> review [label="5. review" color="#ff6b00"]
    review -> refine_check [color="#ff6b00"]
    refine_check -> refine [label="yes" color="#ff6b00"]
    refine_check -> stitch [label="no\n(accept)" color="#28a745"]
    refine -> nano_banana [label="regenerate" color="#ff6b00" style=dashed]

    // Multi-panel stitching
    stitch -> image [label="6. combine\n    panels" color="#2e7d32"]

    // Return path
    agent -> root_session [label="7. path + rationale\n    + suggestions" color="#28a745" style=dashed]
    root_session -> user [label="8. result" color="#2563eb" style=dashed]

    // ── Wiring connections (bundle → runtime) ───────────────────

    context_wire -> root_session [
        label="routing signal\n(loaded every session)"
        style=dotted
        color="#7b5ea7"
    ]

    agent_wire -> agent [
        label="spawns"
        style=dotted
        color="#28a745"
    ]

    tool_nano -> nano_banana [
        label="registers"
        style=dotted
        color="#d4a017"
    ]

    tool_stitch -> stitch [
        label="registers"
        style=dotted
        color="#d4a017"
    ]
}
